# =============================================================================
# AutoInvestor Intelligence System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://autoinvestor:changeme@postgres:5432/autoinvestor
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-change-this
ALGORITHM=HS256
# 43200 minutes = 30 days
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# -----------------------------------------------------------------------------
# Market Data APIs
# -----------------------------------------------------------------------------
# Alpha Vantage — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# Polygon.io — https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_key_here

# NewsAPI — https://newsapi.org/register
NEWS_API_KEY=your_key_here

# Finnhub — https://finnhub.io/dashboard
FINNHUB_API_KEY=your_key_here

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=your@email.com

# Discord Webhook — https://support.discord.com/hc/en-us/articles/228383668
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram — https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# ML Settings
# -----------------------------------------------------------------------------
# Minimum confidence score (0-100) to act on a prediction
MIN_CONFIDENCE_THRESHOLD=65

# Minimum average daily trading volume (shares) to consider a stock
MIN_VOLUME_THRESHOLD=500000

# Minimum stock price in USD to consider
MIN_PRICE_THRESHOLD=5.0

# Maximum number of predictions to surface per nightly scan
MAX_PREDICTIONS_PER_NIGHT=10

# -----------------------------------------------------------------------------
# Trading Profile
# -----------------------------------------------------------------------------
# Trading style: "swing" | "day" | "position"
USER_TRADING_STYLE=swing

# Maximum days to hold a position before forcing a review
MAX_HOLD_DAYS=10

# Risk tolerance: "low" | "medium" | "high"
RISK_TOLERANCE=medium

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
