{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Launch AutoInvestor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "presentation": {
        "group": "AutoInvestor",
        "order": 1
      }
    },
    {
      "name": "🔍 Run Nightly Scan Only",
      "type": "debugpy",
      "request": "launch",
      "module": "app.workers.nightly_analysis",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
