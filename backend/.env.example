# ============================================================
# AutoInvestor Intelligence System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_NAME="AutoInvestor Intelligence System"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
API_V1_PREFIX=/api

# Database
DATABASE_URL=postgresql+asyncpg://autoinvestor:password@localhost:5432/autoinvestor_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_CACHE_TTL=300

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Alpha Vantage API (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=demo

# Polygon.io API (https://polygon.io/)
POLYGON_API_KEY=

# NewsAPI (https://newsapi.org/)
NEWS_API_KEY=

# Finnhub (https://finnhub.io/)
FINNHUB_API_KEY=

# Email Settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="AutoInvestor AI"
NOTIFICATION_EMAIL=recipient@example.com

# Discord Notifications
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ML Configuration
MIN_CONFIDENCE_THRESHOLD=65.0
MIN_CONFIDENCE_FOR_PRIMARY=80.0
MIN_CONFIDENCE_FOR_SECONDARY=70.0
MODEL_STORE_PATH=./model_store
RETRAIN_AFTER_N_PREDICTIONS=50

# Market Configuration
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0
MARKET_TIMEZONE=America/New_York
PRE_MARKET_HOUR=4
AFTER_HOURS_CLOSE_HOUR=20
PRE_MARKET_SCAN_HOUR=6
NIGHTLY_ANALYSIS_HOUR=20
FEEDBACK_RECORDING_HOUR=22

# Portfolio
PORTFOLIO_INITIAL_CASH=100000.0
MAX_POSITION_SIZE_PCT=20.0
MAX_SECTOR_CONCENTRATION_PCT=40.0
DEFAULT_STOP_LOSS_PCT=7.0
MAX_PORTFOLIO_POSITIONS=10

# Risk Management
MAX_PORTFOLIO_VAR_PCT=5.0
MIN_VOLUME_THRESHOLD=500000
MIN_PRICE_THRESHOLD=5.0
MAX_STOCK_PRICE=1000.0

# Feature Flags
ENABLE_ML_PREDICTIONS=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_NOTIFICATIONS=false
ENABLE_SCHEDULER=true
DEMO_MODE=true

# Scheduler
TIMEZONE=America/New_York
