# ─── Application ────────────────────────────────────────────────────────────────
APP_NAME="AutoInvestor Intelligence System"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ─── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/autoinvestor
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ─── API Keys ────────────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key
NEWS_API_KEY=your_news_api_key
FINNHUB_API_KEY=your_finnhub_key

# ─── Email (SMTP) ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME="AutoInvestor"
NOTIFICATION_EMAIL=recipient@example.com

# ─── Discord ─────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ─── Telegram ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── ML / Prediction ─────────────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=65.0
MIN_VOLUME_THRESHOLD=500000
MIN_PRICE_THRESHOLD=5.0
MAX_PORTFOLIO_POSITIONS=10
MODEL_STORE_PATH=./model_store

# ─── Market Hours (ET) ───────────────────────────────────────────────────────────
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0
PRE_MARKET_HOUR=4
AFTER_HOURS_CLOSE_HOUR=20

# ─── CORS ────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# ─── Scheduler ───────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
TIMEZONE=America/New_York
